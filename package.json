{
  "name": "fold",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "type": "module",
  "description": "OSS plan and spikes for encrypted Markdown rooms created by coding agents.",
  "bin": {
    "fold": "./src/cli/bin.ts"
  },
  "scripts": {
    "build": "npm run web:build",
    "start": "tsx src/hosted/bin.ts",
    "cli": "tsx src/cli/bin.ts",
    "server": "tsx src/server/bin.ts",
    "web:dev": "npm run dev --workspace=apps/web",
    "web:build": "npm run build --workspace=apps/web",
    "web:smoke:collab": "tsx scripts/web-collaboration-smoke.ts",
    "web:smoke:agent-comment": "tsx scripts/web-agent-comment-smoke.ts",
    "web:smoke:navigation": "tsx scripts/web-navigation-smoke.ts",
    "web:smoke:annotations": "tsx scripts/web-annotation-theme-smoke.ts",
    "web:smoke:design": "tsx scripts/web-design-direction-smoke.ts",
    "web:smoke:milkdown": "tsx scripts/web-milkdown-lab-smoke.ts",
    "web:smoke:onboarding": "tsx scripts/web-onboarding-smoke.ts",
    "web:smoke:proposal": "tsx scripts/web-proposal-review-smoke.ts",
    "web:smoke:hosted-create": "tsx scripts/web-hosted-create-room-smoke.ts",
    "smoke:deploy": "tsx scripts/hosted-deployment-smoke.ts",
    "spike:e2ee": "tsx spikes/e2ee-yjs-append-log/run-spike.ts",
    "spike:document-model": "vitest run spikes/document-model",
    "spike:document-model:report": "tsx spikes/document-model/run-comparison.ts --check",
    "spike:document-model:report:update": "tsx spikes/document-model/run-comparison.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "web:typecheck": "npm run typecheck --workspace=apps/web",
    "check": "npm test && npm run typecheck && npm run spike:e2ee && npm run spike:document-model && npm run spike:document-model:report && npm run web:typecheck && npm run web:build"
  },
  "dependencies": {
    "@stricli/core": "^1.2.7",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.7",
    "tsx": "^4.22.4",
    "ws": "^8.18.0",
    "yjs": "^13.6.23"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.13",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}

{
  "name": "agent-md-rooms",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "OSS plan and spikes for encrypted Markdown rooms created by coding agents.",
  "bin": {
    "mdroom": "./src/cli/bin.ts"
  },
  "scripts": {
    "cli": "tsx src/cli/bin.ts",
    "server": "tsx src/server/bin.ts",
    "spike:e2ee": "tsx spikes/e2ee-yjs-append-log/run-spike.ts",
    "spike:document-model": "vitest run spikes/document-model",
    "spike:document-model:report": "tsx spikes/document-model/run-comparison.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stricli/core": "^1.2.7",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.7",
    "ws": "^8.18.0",
    "yjs": "^13.6.23"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}

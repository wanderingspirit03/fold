# Production-alpha hosted deploy.
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Same-origin hosted deploy. Set this to the public HTTPS URL users and agents open.
FOLD_PUBLIC_URL=https://your-fold.example

# Hosted persistence. Point this at a mounted volume/disk.
FOLD_DATA_DIR=/persistent/fold/append-log

# Split deploys only: use these instead of FOLD_PUBLIC_URL when the web app
# and append-log sync server are on different origins.
# FOLD_PUBLIC_APP_URL=https://fold-web.example
# FOLD_PUBLIC_SYNC_URL=https://fold-sync.example
# NEXT_PUBLIC_FOLD_SYNC_URL=https://fold-sync.example
